#!/bin/bash

# Pre-push hook: runs unit and integration tests inside Docker before allowing a push.
# Triggers only on feature branches of app teams (e.g. weight/my-feature, billing/fix-bug).
# App branches themselves (weight, billing, frontend) are PR-protected — no direct push allowed.
# Spins up containers, runs tests, tears down — regardless of pass/fail.

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
APP_BRANCHES=("weight" "billing" "frontend")
REPO_ROOT=$(git rev-parse --show-toplevel)

# Check if current branch is a feature branch of an app branch
is_feature_branch=false
for app in "${APP_BRANCHES[@]}"; do
    if [[ "$BRANCH" == "$app/"* ]]; then
        is_feature_branch=true
        APP_FOLDER="$app"
        break
    fi
done

if [ "$is_feature_branch" = false ]; then
    exit 0
fi

APP_PATH="$REPO_ROOT/$APP_FOLDER"

# Verify the app folder exists
if [ ! -d "$APP_PATH" ]; then
    echo "Warning: $APP_FOLDER folder not found. Skipping tests."
    exit 0
fi

# Check for .env file
if [ ! -f "$APP_PATH/.env" ]; then
    echo "Error: No .env file found in $APP_FOLDER."
    echo "Copy .env.example to .env and fill in the values before pushing."
    exit 1
fi

# Find docker-compose file
COMPOSE_FILE=""
for f in docker-compose.dev.yaml docker-compose.dev.yml docker-compose.yaml docker-compose.yml; do
    if [ -f "$APP_PATH/$f" ]; then
        COMPOSE_FILE="$f"
        break
    fi
done

if [ -z "$COMPOSE_FILE" ]; then
    echo "Warning: No docker-compose file found in $APP_FOLDER. Skipping tests."
    exit 0
fi

echo "========================================"
echo "Pre-push hook: running tests for $APP_FOLDER"
echo "========================================"

cd "$APP_PATH"

# Ensure containers are torn down on exit (pass or fail or crash)
cleanup() {
    echo ""
    echo "→ Tearing down containers..."
    docker compose -f "$COMPOSE_FILE" down -v --remove-orphans 2>/dev/null
}
trap cleanup EXIT

# Build and start containers, wait for healthchecks
echo ""
echo "→ Building and starting containers..."
if ! docker compose -f "$COMPOSE_FILE" up --build -d --wait; then
    echo ""
    echo "BUILD FAILED. Push blocked."
    exit 1
fi

# Find the app container
APP_CONTAINER=$(docker compose -f "$COMPOSE_FILE" ps -q app 2>/dev/null)
if [ -z "$APP_CONTAINER" ]; then
    echo "Warning: Could not find app container. Skipping tests."
    exit 0
fi

TEST_RESULT=0

# Run unit tests
if [ -d "tests/unit" ]; then
    echo ""
    echo "→ Running unit tests..."
    if ! docker exec "$APP_CONTAINER" pytest tests/unit -v; then
        echo ""
        echo "UNIT TESTS FAILED. Push blocked."
        TEST_RESULT=1
    else
        echo "Unit tests passed."
    fi
else
    echo "No unit tests found. Skipping."
fi

# Run integration tests (only if unit tests passed)
if [ "$TEST_RESULT" -eq 0 ]; then
    if [ -d "tests/integration" ]; then
        echo ""
        echo "→ Running integration tests..."
        if ! docker exec "$APP_CONTAINER" pytest tests/integration -v; then
            echo ""
            echo "INTEGRATION TESTS FAILED. Push blocked."
            TEST_RESULT=1
        else
            echo "Integration tests passed."
        fi
    else
        echo "No integration tests found. Skipping."
    fi
fi

echo ""
if [ "$TEST_RESULT" -eq 0 ]; then
    echo "========================================"
    echo "All tests passed. Push proceeding."
    echo "========================================"
else
    echo "========================================"
    echo "Tests failed. Push blocked."
    echo "========================================"
fi

exit $TEST_RESULT
