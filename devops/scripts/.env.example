# ============================================================
# CI/CD PIPELINE ENVIRONMENT VARIABLES
#
# DO NOT COPY THIS FILE DIRECTLY TO EC2.
# These variables need to be set in the EC2 environment
# where the scripts can access them — either in:
#   - /etc/environment (system-wide)
#   - ~/.bashrc or ~/.profile (user-level)
#   - The systemd service file for the webhook tool
#     (e.g. /etc/systemd/system/webhook.service)
#
# The webhook tool spawns router.sh, which spawns the
# test and deploy scripts. All of them inherit env vars
# from the webhook process, so setting them in the
# systemd service file is the cleanest approach.
# ============================================================

# ---- Slack ----
SLACK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX

# ---- GitHub (for commit status on PRs) ----
# Personal access token from middlebear78 account
# Required permission: repo:status
# Also used by deploy.sh to push staging → main
# (bypasses branch protection because middlebear78 is admin)
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---- Email (SMTP via Gmail) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=orangeteam.devops@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=orangeteam.devops@gmail.com
EMAIL_TO=orangeteam.devops@gmail.com
